POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
DRY_RUN=false
MIN_ODDS=0.45
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=
AUTO_REDEEM_ENABLED=false
CLAIM_CHECK_INTERVAL=600
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
CHAINLINK_ARB_ENABLED=true
CHAINLINK_MIN_EDGE=0.10
CHAINLINK_MIN_REM=60
CHAINLINK_MAX_REM=240
CHAINLINK_VOLATILITY=0.001
ACTIVE_COINS=BTC
LATE_LIQ_RECENT=20000
LATE_LIQ_SUSTAINED=60000
LATE_CVD_THRESHOLD=30000

# Entry zone dipersempit (dari 210-290 → 230-270)
LATE_ENTRY_MIN=230
LATE_ENTRY_MAX=270

# Beat distance dinaikkan (dari 40 → 60)
LATE_BEAT_DISTANCE=60

# Session blocks: jam UTC yang terbukti WR jelek (dari loss analyzer)
# Format: HH:MM-HH:MM,HH:MM-HH:MM
SESSION_BLOCKS=23:55-01:05,03:55-05:05

# Bad hours UTC (jam dengan WR < 45% per loss analyzer: 2, 4, 7)
# Ini otomatis diblok di dalam engine, SELAIN session blocks di atas
BAD_HOURS_UTC=2,4,7

# Circuit Breaker settings
# Streak ini = mulai cooldown (skip N window)
CB_MAX_STREAK=7
# Streak ini = hard stop, perlu /resume manual via Telegram
CB_HARD_STOP_STREAK=7
# Max total loss per session sebelum hard stop
CB_SESSION_MAX_LOSS=100
# Max drawdown dari saldo awal (0.30 = 30%)
CB_MAX_DRAWDOWN=0.70
